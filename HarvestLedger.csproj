<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>HarvestLedger</AssemblyName>
    <RootNamespace>HarvestLedger</RootNamespace>
    <Version>0.2.0</Version>
    <LangVersion>latest</LangVersion>
    <EnableModDeploy>false</EnableModDeploy>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Pathoschild.Stardew.ModBuildConfig" Version="4.4.0" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="config.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="README.md" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="icon/**/*.png" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
